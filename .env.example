# ── Copy to .env and fill in your values ─────────────────────────────────────
# NEVER commit .env to GitHub

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Database (leave blank for SQLite)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Gmail SMTP Email ──────────────────────────────────────────────────────────
# 1. Enable 2-Step Verification on Gmail: myaccount.google.com/security
# 2. Generate App Password: myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer" -> copy the 16-char password
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=SLMS <your-gmail@gmail.com>

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret
